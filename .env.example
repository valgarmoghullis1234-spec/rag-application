# Copy this file to .env and fill in your values (never commit .env)

# LLM API keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# App login
APP_USERNAME=admin
APP_PASSWORD=changeme123

# Qdrant Cloud (get from cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Backend URL (set this in the frontend Railway service)
BACKEND_URL=https://your-backend.railway.app
